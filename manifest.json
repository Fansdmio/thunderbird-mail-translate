{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.1.8",
  "default_locale": "en",
  "author": "Mail Translate",
  "browser_specific_settings": {
    "gecko": {
      "id": "mail-translate@uuyo.pw",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "messagesRead",
    "messagesModify",
    "storage",
    "tabs",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://api.cognitive.microsofttranslator.com/*"
  ],
  "optional_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "src/shared/languages.js",
      "src/shared/settings.js",
      "src/shared/host-permissions.js",
      "src/shared/html-text.js",
      "src/background/providers/microsoft-free.js",
      "src/background/providers/microsoft-azure.js",
      "src/background/providers/openai-compatible.js",
      "src/background/translate-service.js",
      "src/background/background.js"
    ]
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "message_display_action": {
    "default_title": "__MSG_actionTranslate__",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "64": "src/icons/icon-64.png",
      "96": "src/icons/icon-96.png",
      "128": "src/icons/icon-128.png"
    },
    "theme_icons": [
      {
        "light": "src/icons/icon-light-16.png",
        "dark": "src/icons/icon-16.png",
        "size": 16
      },
      {
        "light": "src/icons/icon-light-32.png",
        "dark": "src/icons/icon-32.png",
        "size": 32
      },
      {
        "light": "src/icons/icon-light-48.png",
        "dark": "src/icons/icon-48.png",
        "size": 48
      },
      {
        "light": "src/icons/icon-light-64.png",
        "dark": "src/icons/icon-64.png",
        "size": 64
      },
      {
        "light": "src/icons/icon-light-96.png",
        "dark": "src/icons/icon-96.png",
        "size": 96
      },
      {
        "light": "src/icons/icon-light-128.png",
        "dark": "src/icons/icon-128.png",
        "size": 128
      }
    ]
  },
  "message_display_scripts": [
    {
      "js": ["src/content/message-display.js"]
    }
  ],
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "64": "src/icons/icon-64.png",
    "96": "src/icons/icon-96.png",
    "128": "src/icons/icon-store-128.png"
  }
}